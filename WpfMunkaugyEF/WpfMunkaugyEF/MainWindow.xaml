<Window x:Class="WpfMunkaugyEF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfMunkaugyEF"
        mc:Ignorable="d"
        Title="Munkaügyi nyilvántartás" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu FontSize="18">
            <MenuItem Header="Fájl"/>
            <MenuItem Header="Szerkesztés"/>
            <MenuItem Header="Nyilvántartás">
                <MenuItem x:Name="menuitemDolgozok" Header="Dolgozók" Click="menuitemDolgozok_Click"/>
                <MenuItem x:Name="menuitemReszlegek" Header="Részlegek" Click="menuitemReszlegek_Click"/>
                <MenuItem x:Name="menuitemAllomany" Header="Állomány" Click="menuitemAllomany_Click"/>
            </MenuItem>
            <MenuItem Header="Súgó"/>

        </Menu>

    </Grid>
</Window>
