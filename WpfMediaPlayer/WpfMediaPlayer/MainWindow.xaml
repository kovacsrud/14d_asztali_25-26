<Window x:Class="WpfMediaPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfMediaPlayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <MediaElement x:Name="mediaPlayer" Margin="10" />
        <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="buttonPlay" Content="Play" Width="100" Height="30" FontSize="16" Margin="0,0,5,0" Click="buttonPlay_Click"/>
            <Button x:Name="buttonPause" Content="Pause" Width="100" Height="30" FontSize="16" Margin="0,0,5,0" Click="buttonPause_Click"/>
            <Button x:Name="buttonStop" Content="Stop" Width="100" Height="30" FontSize="16" Margin="0,0,5,0" Click="buttonStop_Click"/>
            <Button x:Name="buttonOpen" Content="Open" Width="100" Height="30" FontSize="16" Margin="0,0,5,0" Click="buttonOpen_Click"/>
        </WrapPanel>

    </Grid>
</Window>
