<Window x:Class="WpfMunkaugyEF.mvvm.view.NyilvantartasView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfMunkaugyEF.mvvm.view"
        mc:Ignorable="d"
        Title="Nyilvántartás" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <DataGrid ItemsSource="{Binding Nyilvantartas}" AutoGenerateColumns="False" ColumnWidth="*" IsReadOnly="True" Grid.ColumnSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Dolgozó neve" Binding="{Binding Dolgozo.Nev}" />
                <DataGridTextColumn Header="Részleg" Binding="{Binding Reszleg.ReszlegNeve}" />
                <DataGridTextColumn Header="Munkaviszony kezdete" Binding="{Binding MunkaviszonyKezdetenekDatuma}" />
                <DataGridTemplateColumn Header="Aktív munkaviszony">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding AktivDolgozo}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Dolgozó fotója">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Dolgozo.DolgozoKep}" Width="100" Height="100" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="buttonUj" Content="Új dolgozó felvétele" Width="200" Height="30" Grid.Row="1"/>

    </Grid>
</Window>
